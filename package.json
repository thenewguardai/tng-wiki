{
  "name": "@thenewguard/tng-wiki",
  "version": "0.9.1",
  "description": "Keep your LLM wiki honest: a per-claim citation lockfile, drift detection, and code-grounding for Karpathy-style knowledge bases. Scaffolds a fresh wiki or adopts an existing one; agent-agnostic.",
  "keywords": [
    "llm",
    "wiki",
    "knowledge-base",
    "citations",
    "grounding",
    "provenance",
    "drift-detection",
    "agents-md",
    "claude-code",
    "codex",
    "karpathy",
    "markdown",
    "obsidian",
    "ai",
    "research"
  ],
  "author": "The New Guard <hello@thenewguard.ai>",
  "license": "MIT",
  "homepage": "https://thenewguard.ai/features/llm-wiki-guide",
  "repository": {
    "type": "git",
    "url": "https://github.com/thenewguardai/tng-wiki"
  },
  "bin": {
    "tng-wiki": "./bin/cli.js",
    "tng-wiki-mcp": "./bin/tng-wiki-mcp.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.js'",
    "coverage": "node --test --experimental-test-coverage 'test/**/*.test.js'",
    "smoke": "node --check bin/cli.js && node --check bin/tng-wiki-mcp.js && node bin/cli.js --version",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test && npm run smoke",
    "preversion": "npm test",
    "postversion": "git push && git push --tags"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "picocolors": "^1.1.1",
    "zod": "^3.25.76"
  }
}
